{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"types": ["node", "astro/client", "vitest/globals"]
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.astro", "tests/**/*.ts", "tsdown.config.ts", "vitest.config.ts"]
}

